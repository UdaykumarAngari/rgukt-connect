pipeline {
    agent any

    environment {
        IMAGE_NAME = "rgukt-connect-backend"
        CONTAINER_NAME = "rgukt-connect-backend"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build Docker Image') {
            steps {
                dir('backend') {
                    sh "docker build -t ${IMAGE_NAME}:latest ."
                }
            }
        }

        stage('Stop Old Container') {
            steps {
                sh '''
                docker stop ${CONTAINER_NAME} || true
                docker rm ${CONTAINER_NAME} || true
                '''
            }
        }

        stage('Run Backend') {
            steps {
                withCredentials([file(credentialsId: 'rgukt-connect-env', variable: 'ENV_FILE')]) {
                    sh '''
                    docker run -d \
                      --name ${CONTAINER_NAME} \
                      --restart unless-stopped \
                      --env-file "$ENV_FILE" \
                      -p 8000:8000 \
                      ${IMAGE_NAME}:latest
                    '''
                }
            }
        }

        stage('Health Check') {
            steps {
                sh '''
                echo "Waiting for application to become healthy..."

                for i in $(seq 1 30); do
                    if curl -fs http://localhost:8000/actuator/health > /dev/null; then
                        echo "Application is healthy!"
                    exit 0
                fi

                echo "Attempt $i/30: Application not ready yet..."
                sleep 2
            done

            echo "Application failed to become healthy within 60 seconds."

            docker logs ${CONTAINER_NAME}

            exit 1
            '''
            }
        }
    }

    post {
        success {
            echo 'Deployment Successful'
        }

        failure {
            echo 'Deployment Failed x'
        }

        always {
            sh 'docker image prune -f || true'
        }
    }
}